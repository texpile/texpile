# vendored pdf.js modules keep upstream style (see the dir's README.md)
apps/texpile-editor/src/lib/draft/type1/*.js

# vendored LaTeX Workshop package data keeps upstream bytes (see data/VENDORED-LICENSES.md)
apps/texpile-editor/src/lib/editor/extensions/intellisense/data/packages/*.json

# engine reference sources, not ours to format
scratch/

# generated by the Paraglide compiler; each outdir also writes its own .prettierignore, but
# prettier only reads the root one
apps/texpile-editor/src/lib/paraglide/
landing/src/lib/paraglide/

# inlang regenerates everything here except settings.json (see each project.inlang/.gitignore),
# in its own formatting, so prettier must not police it
apps/texpile-editor/project.inlang/*
!apps/texpile-editor/project.inlang/settings.json
landing/project.inlang/*
!landing/project.inlang/settings.json
