# vendored pdf.js modules keep upstream style (see src/lib/draft/type1/README.md)
src/lib/draft/type1/*.js

# vendored LaTeX Workshop package data keeps upstream bytes (see data/VENDORED-LICENSES.md)
src/lib/editor/extensions/intellisense/data/packages/*.json

# generated by the Paraglide compiler; it writes its own .prettierignore in there, but prettier
# only reads the root one, so it has to be repeated here
src/lib/paraglide/

# inlang regenerates everything here except settings.json (see project.inlang/.gitignore), in its
# own formatting, so prettier must not police it
project.inlang/*
!project.inlang/settings.json
